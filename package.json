{
  "name": "native-template",
  "private": true,
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "android": "expo run:android",
    "healthcheck": "npx expo-doctor",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check": "biome check .",
    "fix": "biome check --diagnostic-level=error --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "format": "biome format .",
    "format:write": "biome format . --write",
    "typecheck": "tsgo --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:log": "vitest run --reporter verbose",
    "generate:assets": "bun lib/scripts/generate-static-assets.ts",
    "analyze-bundle": "EXPO_UNSTABLE_ATLAS=true expo export --platform android && echo '📊 Bundle analysis complete! Run: npx expo-atlas' && npx expo-atlas",
    "predev": "bun x expo prebuild; bun run generate:assets",
    "prebuild": "bun run predev",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@lottiefiles/dotlottie-react": "^0.17.15",
    "@react-navigation/drawer": "^7.12.3",
    "@react-navigation/elements": "^2.9.26",
    "@react-navigation/native": "^7.3.4",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@tanstack/react-query": "^5.101.1",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "@ts-utilities/core": "^1.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^54.0.35",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "^15.0.8",
    "expo-image": "^3.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "^6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-server": "^1.0.7",
    "expo-splash-screen": "^31.0.13",
    "expo-system-ui": "^6.0.9",
    "lottie-react-native": "^7.3.8",
    "mime-types": "^3.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.21.13",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "superjson": "^2.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.9.4",
    "@types/react": "~19.1.17",
    "expo-atlas": "^0.4.3",
    "expo-dev-client": "~6.0.21",
    "husky": "^9.1.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "ultracite": "7.0.11",
    "uniwind": "^1.9.0",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": "22.x"
  },
  "author": "Sohan Emon <sohanemon@outlook.com>",
  "description": "A template for creating native apps with Expo and React Native",
  "icon": "/assets/favicon.png",
  "license": "MIT"
}
